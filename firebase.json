{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log"]
    }
  ],
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "functions/**", ".git/**", "*.rules"]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
