rules_version = '2';
// Deploy automatico via GitHub Actions (firebase-deploy.yml) ad ogni push su main.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Admin determinato dall'email autenticata (allowlist), NON da un campo del
    // documento utente: quel campo è scrivibile dall'utente stesso e non deve
    // conferire privilegi. Le email admin sono uniche in Firebase Auth
    // (nessun altro può registrarle) → nessuna auto-promozione possibile.
    function isAdmin() {
      return signedIn() &&
        request.auth.token.email in ['yishionvt@gmail.com', 'admin@lillofind.com'];
    }

    // Impedisce all'utente di scriversi isAdmin:true sul proprio documento
    // (difesa in profondità: le regole non lo usano, ma evita confusione).
    function noSelfAdmin() {
      return !('isAdmin' in request.resource.data)
        || request.resource.data.isAdmin == resource.data.get('isAdmin', false);
    }

    // Products — lettura pubblica, scrittura solo admin
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders — utente legge i propri, admin legge/scrive tutti
    match /orders/{id} {
      allow read:   if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // Users — utente legge/scrive il proprio doc, admin legge tutti
    match /users/{uid} {
      allow read:  if request.auth.uid == uid || isAdmin();
      allow write: if isAdmin() || (request.auth.uid == uid && noSelfAdmin());
    }

    // Richieste prodotto ("non trovo prodotto") — chiunque può inviare, solo admin legge
    match /product_requests/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Avvisami quando disponibile — chiunque può iscriversi, solo admin legge
    match /stock_alerts/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
